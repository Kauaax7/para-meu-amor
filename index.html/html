<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nossa História - Presente</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap');

        :root {
            --spotify-green: #1DB954;
            --spotify-black: #121212;
            --spotify-light-black: #181818;
            --spotify-pink: #E8115B;
            --white: #FFFFFF;
            --gray: #B3B3B3;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Montserrat', sans-serif;
        }

        body {
            background-color: #000;
            color: var(--white);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow: hidden;
        }

        #app-container {
            width: 100%;
            max-width: 390px;
            height: 100vh;
            background-color: var(--spotify-black);
            position: relative;
            display: flex;
            flex-direction: column;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            overflow: hidden;
        }

        /* Slides */
        .slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            padding: 40px 25px 120px 25px; /* Padding extra embaixo para o player */
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            opacity: 0;
            transform: scale(0.95);
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
            pointer-events: none;
            z-index: 1;
        }

        .slide.active {
            opacity: 1;
            transform: scale(1);
            pointer-events: auto;
            z-index: 2;
        }

        /* Tipografia */
        h1 { font-size: 2.2rem; font-weight: 700; margin-bottom: 20px; color: var(--spotify-green); line-height: 1.1; }
        h2 { font-size: 1.5rem; margin-bottom: 15px; color: var(--white); }
        p { font-size: 0.95rem; line-height: 1.6; color: var(--gray); margin-bottom: 15px; }
        .verse { font-style: italic; color: var(--spotify-pink); font-weight: 700; margin-top: 10px; font-size: 0.9rem; }

        /* Spotify Player Widget */
        .music-player-container {
            width: 90%;
            margin-top: 20px;
            border-radius: 12px;
            overflow: hidden;
            background: #000;
            min-height: 80px;
        }

        /* Navegação */
        .nav-buttons {
            position: absolute;
            bottom: 20px;
            width: 100%;
            display: flex;
            justify-content: space-between;
            padding: 0 30px;
            z-index: 20;
        }

        .nav-btn {
            background: rgba(255, 255, 255, 0.1);
            border: none;
            color: white;
            padding: 12px 20px;
            border-radius: 25px;
            cursor: pointer;
            font-weight: bold;
            font-size: 0.8rem;
            backdrop-filter: blur(5px);
        }

        /* Contador */
        #counter {
            background: linear-gradient(145deg, #181818, #282828);
            padding: 20px;
            border-radius: 15px;
            border-left: 4px solid var(--spotify-green);
            width: 100%;
            margin-top: 10px;
        }
        .counter-num { color: var(--spotify-green); font-weight: bold; font-size: 1.3rem; display: block; margin-bottom: 5px; }

        /* Grid de Fotos */
        .photo-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            width: 100%;
            max-height: 55vh;
            overflow-y: auto;
            padding: 10px 5px;
        }
        .photo-item {
            background: #282828;
            padding: 5px;
            border-radius: 8px;
            position: relative;
        }
        .photo-item img {
            width: 100%;
            height: 110px;
            object-fit: cover;
            border-radius: 4px;
        }
        .photo-date { font-size: 0.65rem; color: var(--spotify-green); margin-top: 5px; font-weight: bold; }

        /* Admin */
        #admin-panel {
            position: absolute;
            top: 15px;
            right: 15px;
            z-index: 100;
        }
        #add-photo-btn {
            background: var(--spotify-pink);
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            color: white;
            font-size: 20px;
            cursor: pointer;
            opacity: 0.3; /* Escondido discretamente */
            transition: opacity 0.3s;
        }
        #add-photo-btn:hover { opacity: 1; }
        #file-input { display: none; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-thumb { background: var(--spotify-green); border-radius: 10px; }

    </style>
</head>
<body>

    <div id="app-container">
        <!-- Botão Admin -->
        <div id="admin-panel">
            <button id="add-photo-btn" onclick="checkAdmin()">+</button>
            <input type="file" id="file-input" accept="image/*">
        </div>

        <!-- Tela 1: Abertura + Música -->
        <section class="slide active" id="slide-0">
            <h1>Nossa história</h1>
            <p>Dê o play para começar a nossa jornada...</p>
            
            <div class="music-player-container">
                <!-- Iframe do Spotify -->
                <iframe style="border-radius:12px" src="https://open.spotify.com/embed/track/1DLKuppSYytOuxhtI6KBGu?utm_source=generator&theme=0" width="100%" height="80" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
            </div>
            
            <p style="margin-top: 20px; font-size: 0.8rem; color: var(--spotify-green);">Deslize ou use os botões abaixo</p>
        </section>

        <!-- Tela 2: Timeline -->
        <section class="slide" id="slide-1">
            <h2>Desde o início...</h2>
            <p>🗓️ <strong>02/01/2025</strong><br>Onde nossos caminhos se cruzaram.</p>
            <p>❤️ <strong>05/01/2025</strong><br>Onde o "nós" começou oficialmente.</p>
            <div id="counter">
                <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Estamos juntos há:</span>
                <div id="timer-display">Calculando...</div>
            </div>
        </section>

        <!-- Tela 3: Olhos -->
        <section class="slide" id="slide-2">
            <h2>Seus olhos</h2>
            <p>Eles refletem uma paz que eu nunca imaginei encontrar. O verde mais lindo que já vi.</p>
            <p class="verse">"Como você é linda, minha querida! Ah, como é linda! Os seus olhos são pombas."<br>(Cantares 1:15)</p>
        </section>

        <!-- Tela 4: Sorriso -->
        <section class="slide" id="slide-3">
            <h2>Seu sorriso</h2>
            <p>Ele tem o poder de iluminar o meu dia mais escuro. É o meu abrigo favorito.</p>
            <p class="verse">"A alegria do coração transparece no rosto..."<br>(Provérbios 15:13)</p>
        </section>

        <!-- Tela 5: Cuidado -->
        <section class="slide" id="slide-4">
            <h2>Seu cuidado</h2>
            <p>Obrigado por ser tão atenciosa e por me amar com tanta paciência e dedicação.</p>
            <p class="verse">"O amor é paciente, o amor é bondoso... Tudo sofre, tudo crê, tudo espera, tudo suporta."<br>(1 Coríntios 13:4,7)</p>
        </section>

        <!-- Tela 6: Pensar -->
        <section class="slide" id="slide-5">
            <h2>Seu jeito de pensar</h2>
            <p>Amo como você planeja nosso futuro e como seus sonhos me motivam a ser alguém melhor.</p>
            <p class="verse">"Porque sou eu que conheço os planos que tenho para vocês... planos de fazê-los prosperar."<br>(Jeremias 29:11)</p>
        </section>

        <!-- Tela 7: Fotos -->
        <section class="slide" id="slide-6">
            <h2>Nossos Retratos</h2>
            <div class="photo-grid" id="photo-grid">
                <!-- Fotos via JS -->
            </div>
        </section>

        <!-- Tela 8: Final -->
        <section class="slide" id="slide-7">
            <h1 style="color: var(--spotify-pink);">Feliz aniversário de namoro!</h1>
            <p>Eu amo você, hoje e sempre.</p>
            <p class="verse">"Com amor eterno eu a amei; com amor leal a atraí."<br>(Jeremias 31:3)</p>
            <div style="font-size: 3rem; margin-top: 20px; animation: pulse 2s infinite;">❤️</div>
        </section>

        <!-- Navegação -->
        <div class="nav-buttons">
            <button class="nav-btn" onclick="changeSlide(-1)">Voltar</button>
            <button class="nav-btn" onclick="changeSlide(1)" style="background: var(--spotify-green); color: black;">Avançar</button>
        </div>
    </div>

    <style>
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }
    </style>

    <script>
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide');
        const startDate = new Date('2025-01-05T00:00:00');
        const adminPass = "amor2025"; 

        function changeSlide(direction) {
            slides[currentSlide].classList.remove('active');
            currentSlide = (currentSlide + direction + slides.length) % slides.length;
            slides[currentSlide].classList.add('active');
        }

        function updateCounter() {
            const now = new Date();
            const diff = now - startDate;

            const dias = Math.floor(diff / (1000 * 60 * 60 * 24));
            const horas = Math.floor((diff / (1000 * 60 * 60)) % 24);
            const minutos = Math.floor((diff / 1000 / 60) % 60);
            const segundos = Math.floor((diff / 1000) % 60);

            document.getElementById('timer-display').innerHTML = `
                <span class="counter-num">${dias} dias</span>
                <span style="color: var(--gray); font-size: 0.9rem;">${horas}h ${minutos}m ${segundos}s</span>
            `;
        }
        setInterval(updateCounter, 1000);
        updateCounter();

        // Gerenciamento de Fotos
        const fileInput = document.getElementById('file-input');
        const photoGrid = document.getElementById('photo-grid');

        function checkAdmin() {
            const pass = prompt("Senha de acesso:");
            if (pass === adminPass) fileInput.click();
        }

        fileInput.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const date = prompt("Data ou legenda curta:");
                const reader = new FileReader();
                reader.onload = function(e) {
                    savePhoto(e.target.result, date || "");
                };
                reader.readAsDataURL(file);
            }
        });

        function savePhoto(img, date) {
            let photos = JSON.parse(localStorage.getItem('anniversary_photos') || '[]');
            photos.push({ img, date });
            localStorage.setItem('anniversary_photos', JSON.stringify(photos));
            loadPhotos();
        }

        function loadPhotos() {
            let photos = JSON.parse(localStorage.getItem('anniversary_photos') || '[]');
            photoGrid.innerHTML = photos.length ? '' : '<p style="grid-column: 1/-1; font-size: 0.8rem;">Adicione fotos clicando no + escondido.</p>';
            
            photos.forEach((item, index) => {
                const div = document.createElement('div');
                div.className = 'photo-item';
                div.innerHTML = `
                    <img src="${item.img}">
                    <div class="photo-date">${item.date}</div>
                `;
                div.oncontextmenu = (e) => { // Clique direito ou segurar para deletar
                    e.preventDefault();
                    if(confirm("Apagar foto?")) {
                        photos.splice(index, 1);
                        localStorage.setItem('anniversary_photos', JSON.stringify(photos));
                        loadPhotos();
                    }
                };
                photoGrid.appendChild(div);
            });
        }

        loadPhotos();

        // Swipe para Celular
        let startX = 0;
        document.addEventListener('touchstart', e => startX = e.touches[0].clientX);
        document.addEventListener('touchend', e => {
            let endX = e.changedTouches[0].clientX;
            if (startX - endX > 50) changeSlide(1);
            if (endX - startX > 50) changeSlide(-1);
        });
    </script>
</body>
</html>